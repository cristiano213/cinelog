# CineLog environment configuration template
#
# 1. Copy this file to `.env` in the same directory:
#      cp .env.example .env       (macOS/Linux/Git Bash)
#      Copy-Item .env.example .env (PowerShell)
# 2. Fill in real values below.
# 3. NEVER commit `.env`. It is gitignored by design.

# TMDB API (https://www.themoviedb.org/settings/api)
# Required from Module 0.A. v3 auth key (32 hex chars).
TMDB_API_KEY=your_tmdb_api_key_here

# Supabase project (https://supabase.com/dashboard)
# Required from Module 1. Find under: Project Settings -> API.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Google Places API (https://console.cloud.google.com)
# Required from Module 3. Restrict by package name + API in GCP console.
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here